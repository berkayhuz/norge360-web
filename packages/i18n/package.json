{
  "name": "@workspace/i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "i18n:check": "tsx scripts/check-i18n.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "default": "./src/core/index.ts"
    },
    "./messages": {
      "types": "./src/messages/index.ts",
      "default": "./src/messages/index.ts"
    },
    "./format": {
      "types": "./src/format/index.ts",
      "default": "./src/format/index.ts"
    },
    "./next": {
      "types": "./src/next/index.ts",
      "default": "./src/next/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "default": "./src/testing/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "messages"
  ],
  "peerDependencies": {
    "next-intl": "^4.4.0"
  },
  "devDependencies": {
    "@norge360/eslint-config": "workspace:*",
    "@norge360/typescript-config": "workspace:*",
    "@formatjs/icu-messageformat-parser": "^2.11.4",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10",
    "next-intl": "^4.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
