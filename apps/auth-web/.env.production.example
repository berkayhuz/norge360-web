AUTH_WEB_APP_URL=https://auth.norge360.com
# Point this at the backend gateway that can reach the auth API.
# In the current server layout, this is the backend machine's private IP.
AUTH_API_BASE_URL=http://10.0.0.2:5030
AUTH_COOKIE_DOMAIN=.norge360.com
POST_LOGIN_REDIRECT_URL=/session
ALLOWED_REDIRECT_ORIGINS=https://norge360.com,https://www.norge360.com
AUTH_ACCESS_COOKIE_NAME=Norge360-access
AUTH_REFRESH_COOKIE_NAME=Norge360-refresh
AUTH_SESSION_COOKIE_NAME=Norge360-session
NEXT_PUBLIC_TURNSTILE_SITE_KEY=key
